    "name": "CoffeFlow",
    "description": "Coleccion completa de la API de CoffeFlow (Sistema de Cafeteria). Incluye Auth, Usuarios, Mesas, Productos, Pedidos, Cocina/Inventario, Caja y Notificaciones. Usa el environment 'CoffeFlow - Local' e inicia con el request 'Login - admin' para guardar el token automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5001/api" }
  ],
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Login - admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access_token) { pm.environment.set('token', data.access_token); pm.environment.set('id_usuario_actual', data.usuario.id_usuario); }",
                  "pm.test('Login exitoso (200)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"usuario\": \"admin\",\n  \"contrasena\": \"admin123\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/auth/login" }
          }
        },
        {
          "name": "Login - mesero1",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const data = pm.response.json();",
              "if (data.access_token) { pm.environment.set('token', data.access_token); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"usuario\": \"mesero1\",\n  \"contrasena\": \"mesero123\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/auth/login" }
          }
