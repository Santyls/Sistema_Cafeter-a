{
  "openapi": "3.0.3",
  "info": {
    "title": "CoffeeFlow API Docs",
    "description": "Documentacion interactiva completa de la API de CoffeeFlow: Autenticacion, Usuarios, Mesas, Productos, Pedidos, Cocina (ingredientes/recetas/inventario/alertas), Caja (turnos/tickets/pagos/cortes/gastos/compras) y Notificaciones.",
    "version": "1.1.0"
  },
  "servers": [
    { "url": "http://localhost:5001", "description": "Servidor Local" }
  ],
  "tags": [
    { "name": "Autenticacion", "description": "Inicio de sesion, perfil del usuario autenticado y recuperacion de contrasena." },
    { "name": "Usuarios", "description": "Gestion de usuarios y roles del sistema (solo administrador)." },
    { "name": "Mesas", "description": "Consulta y administracion de las mesas del restaurante." },
    { "name": "Productos y Categorias", "description": "Catalogo de categorias y productos del menu." },
    { "name": "Pedidos", "description": "Ciclo de vida completo de los pedidos: crear, actualizar, cambiar estado, cancelar e historial." },
    { "name": "Cocina - Ingredientes y Recetas", "description": "Catalogo de ingredientes y las recetas que los relacionan con productos." },
    { "name": "Cocina - Inventario y Alertas", "description": "Movimientos de inventario (entradas/salidas/ajustes) y alertas de stock bajo." },
    { "name": "Caja - Turnos y Tickets", "description": "Apertura/cierre de turnos de caja, tickets de venta y registro de pagos." },
    { "name": "Caja - Cortes, Gastos y Compras", "description": "Cortes de caja, gastos operativos y compras de suministro." },
    { "name": "Notificaciones", "description": "Notificaciones internas entre modulos (pedido listo, stock bajo, etc.)." }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  },
  "security": [ { "BearerAuth": [] } ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticacion"],
        "summary": "Iniciar sesion",
        "description": "Autentica por usuario o correo y devuelve el token JWT de acceso junto con los datos del usuario.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "usuario": { "type": "string", "example": "admin" },
              "correo": { "type": "string", "example": "admin@cafeteria.com" },
              "contrasena": { "type": "string", "example": "admin123" }
            },
            "required": ["contrasena"]
          } } }
        },
        "responses": {
          "200": { "description": "Sesion iniciada con exito" },
          "400": { "description": "Faltan usuario/correo o contrasena" },
          "401": { "description": "Credenciales invalidas" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Autenticacion"],
        "summary": "Cerrar sesion",
        "responses": { "200": { "description": "Sesion cerrada" } }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Autenticacion"],
        "summary": "Obtener perfil del usuario autenticado",
        "responses": { "200": { "description": "Datos del usuario" }, "404": { "description": "Usuario no encontrado" } }
      }
    },
    "/api/auth/recuperar-password": {
      "post": {
        "tags": ["Autenticacion"],
        "summary": "Solicitar recuperacion de contrasena",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": { "correo": { "type": "string", "example": "admin@cafeteria.com" } },
            "required": ["correo"]
          } } }
        },
        "responses": { "200": { "description": "Instrucciones enviadas (si el correo existe)" }, "400": { "description": "correo es requerido" } }
      }
    },

    "/api/usuarios": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Listar usuarios",
        "parameters": [ { "name": "rol", "in": "query", "schema": { "type": "string", "enum": ["admin", "mesero", "cocinero", "cajero"] } } ],
        "responses": { "200": { "description": "Listado de usuarios" } }
      },
      "post": {
        "tags": ["Usuarios"],
        "summary": "Crear usuario",
        "description": "Solo administrador.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "nombre": { "type": "string", "example": "Roberto" },
              "apellido_paterno": { "type": "string", "example": "Gomez" },
              "apellido_materno": { "type": "string", "example": "Diaz" },
              "telefono": { "type": "string", "example": "4421234567" },
              "correo": { "type": "string", "example": "roberto.mesero@cafeteria.com" },
              "usuario": { "type": "string", "example": "mesero3" },
              "contrasena": { "type": "string", "example": "mesero123" },
              "rol": { "type": "string", "enum": ["admin", "mesero", "cocinero", "cajero"], "example": "mesero" }
            },
            "required": ["nombre", "correo", "usuario", "contrasena", "rol"]
          } } }
        },
        "responses": { "201": { "description": "Usuario creado" }, "409": { "description": "Correo o usuario ya en uso" } }
      }
    },
    "/api/usuarios/{id_usuario}": {
      "get": { "tags": ["Usuarios"], "summary": "Obtener usuario", "parameters": [ { "name": "id_usuario", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Usuario" }, "404": { "description": "No encontrado" } } },
      "put": {
        "tags": ["Usuarios"],
        "summary": "Actualizar usuario",
        "parameters": [ { "name": "id_usuario", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": {
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "telefono": { "type": "string", "example": "4429876543" },
              "correo": { "type": "string", "example": "nuevo.correo@cafeteria.com" },
              "activo": { "type": "boolean", "example": true },
              "contrasena": { "type": "string", "example": "nuevaClave123" },
              "rol": { "type": "string", "enum": ["admin", "mesero", "cocinero", "cajero"] }
            }
          } } }
        },
        "responses": { "200": { "description": "Usuario actualizado" }, "404": { "description": "No encontrado" } }
      },
      "delete": { "tags": ["Usuarios"], "summary": "Eliminar usuario", "parameters": [ { "name": "id_usuario", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Eliminado" }, "400": { "description": "Un admin no puede eliminarse a si mismo" } } }
    },

    "/api/mesas": {
      "get": {
        "tags": ["Mesas"],
        "summary": "Listar mesas",
        "parameters": [ { "name": "estado", "in": "query", "schema": { "type": "string", "enum": ["disponible", "ocupada", "reservada"] } } ],
        "responses": { "200": { "description": "Listado de mesas" } }
      },
      "post": {
        "tags": ["Mesas"],
        "summary": "Crear mesa",
        "description": "Solo administrador.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "numero_mesa": { "type": "integer", "example": 9 },
              "capacidad": { "type": "integer", "example": 6 },
              "ubicacion": { "type": "string", "example": "Terraza" },
              "estado": { "type": "string", "enum": ["disponible", "ocupada", "reservada"], "example": "disponible" }
            },
            "required": ["numero_mesa"]
          } } }
        },
        "responses": { "201": { "description": "Mesa creada" } }
      }
    },
    "/api/mesas/{id_mesa}": {
      "get": { "tags": ["Mesas"], "summary": "Obtener mesa", "parameters": [ { "name": "id_mesa", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Mesa" }, "404": { "description": "No encontrada" } } },
      "put": {
        "tags": ["Mesas"],
        "summary": "Actualizar mesa",
        "description": "Solo administrador.",
        "parameters": [ { "name": "id_mesa", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": {
            "capacidad": { "type": "integer", "example": 8 },
            "ubicacion": { "type": "string", "example": "Terraza ampliada" },
            "numero_mesa": { "type": "integer" },
            "estado": { "type": "string", "enum": ["disponible", "ocupada", "reservada"] }
          }
        } } } },
        "responses": { "200": { "description": "Mesa actualizada" }, "404": { "description": "No encontrada" } }
      },
      "delete": { "tags": ["Mesas"], "summary": "Eliminar mesa", "description": "Solo administrador.", "parameters": [ { "name": "id_mesa", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Eliminada" }, "404": { "description": "No encontrada" } } }
    },
    "/api/mesas/{id_mesa}/estado": {
      "patch": {
        "tags": ["Mesas"],
        "summary": "Cambiar estado de mesa",
        "parameters": [ { "name": "id_mesa", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": { "estado": { "type": "string", "enum": ["disponible", "ocupada", "reservada"], "example": "ocupada" } },
            "required": ["estado"]
          } } }
        },
        "responses": { "200": { "description": "Estado actualizado" }, "400": { "description": "Estado invalido" }, "404": { "description": "No encontrada" } }
      }
    },

    "/api/categorias": {
      "get": { "tags": ["Productos y Categorias"], "summary": "Listar categorias", "responses": { "200": { "description": "Listado de categorias" } } },
      "post": {
        "tags": ["Productos y Categorias"],
        "summary": "Crear categoria",
        "description": "Solo administrador.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "nombre": { "type": "string", "example": "Desayunos" },
              "descripcion": { "type": "string", "example": "Platillos de desayuno" },
              "activo": { "type": "boolean", "example": true }
            },
            "required": ["nombre"]
          } } }
        },
        "responses": { "201": { "description": "Categoria creada" } }
      }
    },
    "/api/categorias/{id_categoria}": {
      "put": {
        "tags": ["Productos y Categorias"],
        "summary": "Actualizar categoria",
        "description": "Solo administrador.",
        "parameters": [ { "name": "id_categoria", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": { "nombre": { "type": "string" }, "descripcion": { "type": "string", "example": "Platillos de desayuno y brunch" }, "activo": { "type": "boolean" } }
        } } } },
        "responses": { "200": { "description": "Categoria actualizada" }, "404": { "description": "No encontrada" } }
      },
      "delete": { "tags": ["Productos y Categorias"], "summary": "Eliminar categoria", "description": "Solo administrador.", "parameters": [ { "name": "id_categoria", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Eliminada" }, "404": { "description": "No encontrada" } } }
    },
    "/api/productos": {
      "get": {
        "tags": ["Productos y Categorias"],
        "summary": "Listar productos (ver menu)",
        "parameters": [
          { "name": "id_categoria", "in": "query", "schema": { "type": "integer" } },
          { "name": "disponible", "in": "query", "schema": { "type": "string", "enum": ["true", "false"] } }
        ],
        "responses": { "200": { "description": "Catalogo de productos" } }
      },
      "post": {
        "tags": ["Productos y Categorias"],
        "summary": "Crear producto",
        "description": "Solo administrador.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "nombre": { "type": "string", "example": "Chilaquiles Verdes" },
              "descripcion": { "type": "string", "example": "Chilaquiles banados en salsa verde con pollo" },
              "precio": { "type": "number", "example": 95 },
              "id_categoria": { "type": "integer", "example": 1 },
              "imagen": { "type": "string", "nullable": true },
              "disponible": { "type": "boolean", "example": true }
            },
            "required": ["nombre", "precio"]
          } } }
        },
        "responses": { "201": { "description": "Producto creado" } }
      }
    },
    "/api/productos/{id_producto}": {
      "get": { "tags": ["Productos y Categorias"], "summary": "Obtener producto", "parameters": [ { "name": "id_producto", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Producto" }, "404": { "description": "No encontrado" } } },
      "put": {
        "tags": ["Productos y Categorias"],
        "summary": "Actualizar producto",
        "description": "Solo administrador.",
        "parameters": [ { "name": "id_producto", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": { "precio": { "type": "number", "example": 99 }, "disponible": { "type": "boolean", "example": true }, "nombre": { "type": "string" }, "descripcion": { "type": "string" }, "id_categoria": { "type": "integer" } }
        } } } },
        "responses": { "200": { "description": "Producto actualizado" }, "404": { "description": "No encontrado" } }
      },
      "delete": { "tags": ["Productos y Categorias"], "summary": "Eliminar producto", "description": "Solo administrador.", "parameters": [ { "name": "id_producto", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Eliminado" }, "404": { "description": "No encontrado" } } }
    },

    "/api/pedidos": {
      "get": {
        "tags": ["Pedidos"],
        "summary": "Listar pedidos",
        "parameters": [
          { "name": "estado", "in": "query", "schema": { "type": "string", "enum": ["pendiente", "en_preparacion", "listo", "entregado", "cancelado"] } },
          { "name": "id_mesa", "in": "query", "schema": { "type": "integer" } },
          { "name": "id_usuario", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Listado de pedidos" } }
      },
      "post": {
        "tags": ["Pedidos"],
        "summary": "Crear pedido (levantar orden)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "id_mesa": { "type": "integer", "example": 1 },
              "observaciones": { "type": "string", "example": "Cliente frecuente, mesa junto a la ventana" },
              "metodo_pago": { "type": "string", "nullable": true },
              "detalles": {
                "type": "array",
                "items": { "type": "object", "properties": {
                  "id_producto": { "type": "integer", "example": 1 },
                  "cantidad": { "type": "integer", "example": 2 },
                  "observaciones": { "type": "string", "example": "Sin azucar" }
                } }
              }
            },
            "required": ["id_mesa", "detalles"]
          } } }
        },
        "responses": { "201": { "description": "Pedido registrado" }, "404": { "description": "Mesa o producto no encontrado" }, "409": { "description": "Producto no disponible" } }
      }
    },
    "/api/pedidos/{id_pedido}": {
      "get": { "tags": ["Pedidos"], "summary": "Obtener detalle del pedido", "parameters": [ { "name": "id_pedido", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Pedido con detalles e historial" }, "404": { "description": "No encontrado" } } },
      "put": {
        "tags": ["Pedidos"],
        "summary": "Actualizar pedido",
        "description": "Bloqueado si el pedido esta en listo, entregado o cancelado.",
        "parameters": [ { "name": "id_pedido", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": {
            "observaciones": { "type": "string", "example": "Agregar un cafe mas" },
            "metodo_pago": { "type": "string", "example": "tarjeta" },
            "detalles": {
              "type": "array",
              "items": { "type": "object", "properties": { "id_producto": { "type": "integer" }, "cantidad": { "type": "integer" } } }
            }
          }
        } } } },
        "responses": { "200": { "description": "Pedido actualizado" }, "404": { "description": "No encontrado" }, "409": { "description": "Pedido no editable en su estado actual" } }
      },
      "delete": { "tags": ["Pedidos"], "summary": "Cancelar pedido", "description": "Solo si el pedido esta pendiente o en_preparacion.", "parameters": [ { "name": "id_pedido", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Pedido cancelado" }, "409": { "description": "No se puede cancelar en su estado actual" } } }
    },
    "/api/pedidos/{id_pedido}/estado": {
      "patch": {
        "tags": ["Pedidos"],
        "summary": "Cambiar estado del pedido",
        "description": "pendiente -> en_preparacion -> listo (descuenta inventario y notifica al mesero) -> entregado (libera la mesa). cancelado tambien libera la mesa.",
        "parameters": [ { "name": "id_pedido", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "estado": { "type": "string", "enum": ["pendiente", "en_preparacion", "listo", "entregado", "cancelado"], "example": "listo" },
              "comentario": { "type": "string", "example": "Terminado a tiempo" }
            },
            "required": ["estado"]
          } } }
        },
        "responses": { "200": { "description": "Estado actualizado" }, "400": { "description": "Estado invalido" }, "409": { "description": "El pedido ya esta entregado/cancelado" } }
      }
    },
    "/api/pedidos/{id_pedido}/historial": {
      "get": { "tags": ["Pedidos"], "summary": "Ver historial de estados del pedido", "parameters": [ { "name": "id_pedido", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Bitacora de cambios de estado" } } }
    },

    "/api/ingredientes": {
      "get": {
        "tags": ["Cocina - Ingredientes y Recetas"],
        "summary": "Listar ingredientes",
        "parameters": [ { "name": "stock_bajo", "in": "query", "schema": { "type": "string", "enum": ["true", "false"] }, "description": "Filtra solo los que estan por debajo del stock minimo" } ],
        "responses": { "200": { "description": "Listado de ingredientes" } }
      },
      "post": {
        "tags": ["Cocina - Ingredientes y Recetas"],
        "summary": "Crear ingrediente",
        "description": "Administrador o cocinero.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "nombre": { "type": "string", "example": "Canela en polvo" },
              "unidad_medida": { "type": "string", "example": "kg" },
              "stock_actual": { "type": "number", "example": 3 },
              "stock_minimo": { "type": "number", "example": 1 },
              "activo": { "type": "boolean", "example": true }
            },
            "required": ["nombre", "unidad_medida"]
          } } }
        },
        "responses": { "201": { "description": "Ingrediente creado" } }
      }
    },
    "/api/ingredientes/{id_ingrediente}": {
      "get": { "tags": ["Cocina - Ingredientes y Recetas"], "summary": "Obtener ingrediente", "parameters": [ { "name": "id_ingrediente", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Ingrediente" }, "404": { "description": "No encontrado" } } },
      "put": {
        "tags": ["Cocina - Ingredientes y Recetas"],
        "summary": "Actualizar ingrediente",
        "description": "Administrador o cocinero.",
        "parameters": [ { "name": "id_ingrediente", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": { "stock_actual": { "type": "number", "example": 5 }, "stock_minimo": { "type": "number" }, "nombre": { "type": "string" }, "unidad_medida": { "type": "string" }, "activo": { "type": "boolean" } }
        } } } },
        "responses": { "200": { "description": "Ingrediente actualizado" }, "404": { "description": "No encontrado" } }
      },
      "delete": { "tags": ["Cocina - Ingredientes y Recetas"], "summary": "Eliminar ingrediente", "description": "Administrador o cocinero.", "parameters": [ { "name": "id_ingrediente", "in": "path", "required": true, "schema": { "type": "integer" } } ], "responses": { "200": { "description": "Eliminado" }, "404": { "description": "No encontrado" } } }
    },
    "/api/recetas": {
      "get": {
        "tags": ["Cocina - Ingredientes y Recetas"],
        "summary": "Listar recetas",
        "parameters": [ { "name": "id_producto", "in": "query", "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Listado de recetas" } }
      },
      "post": {
        "tags": ["Cocina - Ingredientes y Recetas"],
        "summary": "Crear receta",
        "description": "Administrador o cocinero. Relaciona un producto con un ingrediente y la cantidad que consume.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "id_producto": { "type": "integer", "example": 1 },
              "id_ingrediente": { "type": "integer", "example": 4 },
              "cantidad_requerida": { "type": "number", "example": 0.01 }
            },
            "required": ["id_producto", "id_ingrediente", "cantidad_requerida"]
          } } }
        },
        "responses": { "201": { "description": "Receta creada" } }
      }
    },
    "/api/recetas/{id_receta}": {
